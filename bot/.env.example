# ============================================================================
# Boundless Info - Steam discovery bot environment
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in REAL values LOCALLY ONLY.
# NEVER commit `.env`. On GitHub Actions these become repository Secrets.
# NEVER put real values in this example file.
# ============================================================================

# --- Steam account (owner's own). Used to mint the Steam auth ticket for
#     Boundless (app id 324510). First login triggers a one-time Steam Guard
#     2FA prompt; after that the persisted sentry makes logins headless.
STEAM_USERNAME=
STEAM_PASSWORD=

# --- Boundless web / forum account (the playboundless.com login). Used for the
#     web session -> game JWT. Often the same person, different credentials
#     than Steam.
BOUNDLESS_USERNAME=
BOUNDLESS_PASSWORD=

# --- Boundless ACCOUNT username (the in-game/account handle, e.g. "Kanjiro77").
#     Used ONLY in the DS /gameserver path. Verified: this differs from the web
#     login email above AND from the character name; only the account username
#     is accepted by the discovery server. If unset, falls back to BOUNDLESS_USERNAME.
BOUNDLESS_ACCOUNT_USERNAME=

# --- Our ingest API ---
# Bearer token the Worker checks on POST /api/ingest/worlds.
INGEST_TOKEN=
# Base URL of the Boundless Info API Worker. Default is the production Worker.
API_BASE=https://boundlessinfo-api.niccolo-sabato.workers.dev

# --- Discovery server (the game's universe/discovery server). Default is the
#     live universe used by Boundlexx. Include the :8902 port.
DS_BASE=https://ds.playboundless.com:8902

# --- Scan window: inclusive range of world ids to probe each run.
#     World ids are small integers. Permanent + exo + sovereign live worlds sit
#     in a low range; exos cluster near the highest known id. Examples:
#       full sweep:    SCAN_MIN=1     SCAN_MAX=5000
#       recent window: SCAN_MIN=7800  SCAN_MAX=7999
#     Start narrow while verifying, then widen.
SCAN_MIN=1
SCAN_MAX=5000

# --- For `npm run spike` only: a single known-live world id to probe end to end.
SPIKE_WORLD_ID=

# --- Optional tuning (sane defaults; uncomment to override) ---
# Delay in ms between DS probes (be polite). Default 1000.
# DS_DELAY_MS=1000
# Delay in ms between per-world apiURL calls. Default 1000.
# WORLD_DELAY_MS=1000
# Per-request timeout in ms. Default 8000.
# REQUEST_TIMEOUT_MS=8000
